<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="SingleSortingResultDto.fs" />
    <Compile Include="SplitPairsSortingResultDto.fs" />
    <Compile Include="PairsSortingResultDto.fs" />
    <Compile Include="SortingResultDto.fs" />
    <Compile Include="SortingResultMapDto.fs" />
    <Compile Include="SortingResultSetMapDto.fs" />
    <Compile Include="MutationSegmentResultsDto.fs" />
    <Compile Include="MutationSegmentSetResultsDto.fs" />
    <Compile Include="Bins\SorterEvalBinsDto.fs" />
    <Compile Include="Bins\SingleSortingEvalBinsDto.fs" />
    <Compile Include="Bins\SplitPairSortingEvalBinsDto.fs" />
    <Compile Include="Bins\PairEvalBinsDto.fs" />
    <Compile Include="Bins\SortingEvalBinsDto.fs" />
    <Compile Include="Bins\MutationSegmentEvalBinsDto.fs" />
    <Compile Include="Bins\MutationSegmentEvalBinsSetDto.fs" />
    <Compile Include="Bins\SorterEvalHierarchyDto.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FSharp.UMX" Version="1.1.0" />
    <PackageReference Include="FsToolkit.ErrorHandling" Version="5.1.0" />
    <PackageReference Include="MessagePack" Version="3.1.4" />
    <PackageReference Include="MessagePack.FSharpExtensions" Version="4.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\GeneSort.Core.Mp\GeneSort.Core.Mp.fsproj" />
    <ProjectReference Include="..\GeneSort.Core\GeneSort.Core.fsproj" />
    <ProjectReference Include="..\GeneSort.Model.Mp\GeneSort.Model.Mp.fsproj" />
    <ProjectReference Include="..\GeneSort.SortingOps.Mp\GeneSort.SortingOps.Mp.fsproj" />
    <ProjectReference Include="..\GeneSort.SortingOps\GeneSort.SortingOps.fsproj" />
    <ProjectReference Include="..\GeneSort.SortingResults\GeneSort.SortingResults.fsproj" />
    <ProjectReference Include="..\GeneSort.Sorting\GeneSort.Sorting.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Update="FSharp.Core" Version="10.0.102" />
  </ItemGroup>

</Project>

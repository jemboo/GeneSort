<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Common.fs" />
    <Compile Include="SingleSortingResult.fs" />
    <Compile Include="SplitPairsSortingResult.fs" />
    <Compile Include="PairsSortingResult.fs" />
    <Compile Include="SortingResult.fs" />
    <Compile Include="SortingResultMap.fs" />
    <Compile Include="SortingResultSetMap.fs" />
    <Compile Include="MutationSegmentResults.fs" />
    <Compile Include="MutationSegmentSetResults.fs" />
    <Compile Include="Bins\SorterEvalKey.fs" />
    <Compile Include="Bins\SortingEvalKeys.fs" />
    <Compile Include="Bins\SorterEvalLeaf.fs" />
    <Compile Include="Bins\SorterEvalBins.fs" />
    <Compile Include="Bins\SingleSortingEvalBins.fs" />
    <Compile Include="Bins\SplitPairSortingEvalBins.fs" />
    <Compile Include="Bins\PairSortingEvalBins.fs" />
    <Compile Include="Bins\SortingEvalBins.fs" />
    <Compile Include="Bins\MutationSegmentEvalBins.fs" />
    <Compile Include="Bins\SorterEvalHierarchy.fs" />
    <Compile Include="Bins\SorterEvalLayerStats.fs" />
    <Compile Include="Bins\SorterEvalBinStats.fs" />
    <Compile Include="SortingSetFilter.fs" />
    <Compile Include="SorterSetCeUseProfile.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FSharp.UMX" Version="1.1.0" />
    <PackageReference Include="FsToolkit.ErrorHandling" Version="5.1.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\GeneSort.Core\GeneSort.Core.fsproj" />
    <ProjectReference Include="..\GeneSort.SortingOps\GeneSort.SortingOps.fsproj" />
    <ProjectReference Include="..\GeneSort.Sorting\GeneSort.Sorting.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Update="FSharp.Core" Version="10.0.102" />
  </ItemGroup>

</Project>

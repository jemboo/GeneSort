<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Common.fs" />
    <Compile Include="SingleSortingEval.fs" />
    <Compile Include="SplitPairsSortingEval.fs" />
    <Compile Include="PairsSortingEval.fs" />
    <Compile Include="SortingEval.fs" />
    <Compile Include="SortingEvalMap.fs" />
    <Compile Include="SortingEvalSetMap.fs" />
    <Compile Include="MutationSegmentEvals.fs" />
    <Compile Include="MutationSegmentSetEvals.fs" />
    <Compile Include="Bins\SorterEvalKey.fs" />
    <Compile Include="Bins\SortingEvalKeys.fs" />
    <Compile Include="Bins\SorterEvalLeaf.fs" />
    <Compile Include="Bins\SorterEvalBins.fs" />
    <Compile Include="Bins\SingleSortingEvalBins.fs" />
    <Compile Include="Bins\SplitPairSortingEvalBins.fs" />
    <Compile Include="Bins\PairSortingEvalBins.fs" />
    <Compile Include="Bins\SortingEvalBins.fs" />
    <Compile Include="Bins\MutationSegmentEvalBins.fs" />
    <Compile Include="Bins\MutationSegmentEvalBinsSet.fs" />
    <Compile Include="Bins\SorterEvalHierarchy.fs" />
